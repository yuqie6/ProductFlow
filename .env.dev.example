# ProductFlow development example.
# Copy to .env.dev for dev ports, Redis DB 1, and storage-dev. Do not commit .env.dev.
# Use just commands to load this file; do not shell-source production .env for local development.

# Auth (env-only; use local random values)
ADMIN_ACCESS_KEY=replace-with-a-long-random-dev-admin-key
SETTINGS_ACCESS_TOKEN=replace-with-a-separate-dev-settings-token
SESSION_SECRET=replace-with-another-long-random-dev-session-secret

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=29282
WEB_PORT=29283
BACKEND_CORS_ORIGINS=http://localhost:29283,http://127.0.0.1:29283
SESSION_COOKIE_SECURE=false

# Persistence. The database name matches docker-compose.yml's default POSTGRES_DB.
POSTGRES_PASSWORD=replace-with-a-random-postgres-password
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+psycopg://productflow:replace-with-a-random-postgres-password@localhost:15432/productflow
REDIS_HOST_PORT=16379
REDIS_URL=redis://localhost:16379/1
STORAGE_ROOT=./backend/storage-dev

# Text provider
TEXT_PROVIDER_KIND=mock
TEXT_API_KEY=
TEXT_BASE_URL=
TEXT_BRIEF_MODEL=gpt-4o
TEXT_COPY_MODEL=gpt-4o

# Image provider
IMAGE_PROVIDER_KIND=mock
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_GENERATE_MODEL=gpt-5.4
IMAGE_MAIN_IMAGE_SIZE=1024x1024
IMAGE_PROMO_POSTER_SIZE=1024x1536
IMAGE_ALLOWED_SIZES=1024x1024,1024x1536,1536x1024

# Poster generation
POSTER_GENERATION_MODE=template

# Poster rendering
POSTER_FONT_PATH=/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc

# Upload safety
UPLOAD_MAX_IMAGE_BYTES=10485760
UPLOAD_MAX_REFERENCE_IMAGES=6
UPLOAD_MAX_PIXELS=16000000
UPLOAD_ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp

# Jobs
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_MS=10000
GENERATION_MAX_CONCURRENT_TASKS=3
WORKFLOW_IMAGE_GENERATION_PROVIDER_TIMEOUT_SECONDS=900
