# Project Trellis/Codex helpers are source-controlled. Ignore only local state,
# runtime output, caches, and per-developer workspace records.
.trellis/.developer
.trellis/.current-task
.trellis/.ralph-state.json
.trellis/.agent-log
.trellis/.session-id
.trellis/.plan-log
.trellis/.backup-*/
.trellis/.cache/
.trellis/cache/
.trellis/.runtime/
.trellis/runtime/
.trellis/workspace/*/
.trellis/tasks/
.trellis/**/*.tmp
.trellis/**/*.new
.trellis/**/*.py[cod]

# Root-level .agents/ and .codex/ helper definitions should be visible to git;
# keep only generated/runtime output and local overrides out of source control.
.agents/**/.cache/
.agents/**/node_modules/
.agents/**/*.local.*
.codex/logs/
.codex/sessions/
.codex/tmp/
.codex/**/*.local.*
.codex/**/*.py[cod]
