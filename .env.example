# ProductFlow production-style self-hosted example.
# Copy to .env and replace every placeholder before exposing the app.

# Auth (env-only; never commit real values)
ADMIN_ACCESS_KEY=replace-with-a-long-random-admin-key
SETTINGS_ACCESS_TOKEN=replace-with-a-separate-settings-token
SESSION_SECRET=replace-with-another-long-random-session-secret

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=29280
WEB_PORT=29281
APP_HOST_PORT=29280
BACKEND_CORS_ORIGINS=http://localhost:29281,http://127.0.0.1:29281
SESSION_COOKIE_SECURE=false

# Persistence (env-only)
POSTGRES_PASSWORD=replace-with-a-random-postgres-password
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+psycopg://productflow:replace-with-a-random-postgres-password@productflow-postgres:5432/productflow
REDIS_HOST_PORT=16379
REDIS_URL=redis://productflow-redis:6379/0

# Container runtime storage root stays fixed at /app/storage. For production reuse/migration from the
# old systemd release, bind-mount the existing host directory by setting STORAGE_HOST_PATH, for example:
# STORAGE_HOST_PATH=/home/cot/ProductFlow-release/shared/storage
# Leave STORAGE_HOST_PATH unset to use the default Docker named volume productflow-storage.
STORAGE_ROOT=/app/storage
# STORAGE_HOST_PATH=

# Text provider. Keep mock for local smoke tests without external API keys.
TEXT_PROVIDER_KIND=mock
TEXT_API_KEY=
TEXT_BASE_URL=
TEXT_BRIEF_MODEL=gpt-4o
TEXT_COPY_MODEL=gpt-4o

# Image provider. Keep mock unless you have configured a Responses image provider.
IMAGE_PROVIDER_KIND=mock
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_GENERATE_MODEL=gpt-5.4
IMAGE_MAIN_IMAGE_SIZE=1024x1024
IMAGE_PROMO_POSTER_SIZE=1024x1536
IMAGE_ALLOWED_SIZES=1024x1024,1024x1536,1536x1024

# Poster generation: template does not call the image provider; generated does.
POSTER_GENERATION_MODE=template

# Poster rendering
POSTER_FONT_PATH=/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc

# Upload safety
UPLOAD_MAX_IMAGE_BYTES=10485760
UPLOAD_MAX_REFERENCE_IMAGES=6
UPLOAD_MAX_PIXELS=16000000
UPLOAD_ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp

# Jobs
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_MS=10000
GENERATION_MAX_CONCURRENT_TASKS=3
WORKFLOW_IMAGE_GENERATION_PROVIDER_TIMEOUT_SECONDS=900
